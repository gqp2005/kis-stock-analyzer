KIS_APP_KEY=your_kis_app_key
KIS_APP_SECRET=your_kis_app_secret
# Optional
# KIS_BASE_URL=https://openapi.koreainvestment.com:9443
# KIS_ENV=real
# KIS_ACCOUNT_NO=12345678
# KIS_ACCOUNT_PRDT_CD=01
# KIS_KV is a Cloudflare KV binding (set in Pages/Workers bindings, not in .dev.vars)
# AUTOTRADE_KV is a Cloudflare KV binding (포지션/손실/쿨다운 상태 저장)
# RATE_LIMIT_MAX_REQUESTS=120
# RATE_LIMIT_WINDOW_SEC=60
# ADMIN_TOKEN=change-me
# SITE_AUTH_PASSWORD=change-me-strong-password
# SITE_AUTH_USERNAME=owner
# SITE_AUTH_COOKIE_SECRET=change-me-cookie-secret
# SITE_AUTH_SESSION_HOURS=12
# SITE_AUTH_DEBUG=true
# SCREENER_AUTO_BOOTSTRAP=true
# SCREENER_AUTO_BOOTSTRAP_BATCH=20
